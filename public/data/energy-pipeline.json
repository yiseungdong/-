{
  "meta": {
    "version": "1.0.0",
    "description": "아스테리아 에너지 합산 파이프라인",
    "principle": "개인의 활동이 유닛→베이스→테리토리→팬클럽으로 합산되어 리그 전체의 에너지가 된다",
    "totalStages": 4
  },
  "pipeline": [
    {
      "stage": 1,
      "name": "개인 → 유닛",
      "nameEn": "Individual → Unit",
      "id": "individual_to_unit",
      "formula": "UnitEnergy = Σ(개인AP) × 참여율",
      "formulaCode": "UnitEnergy = sum(memberAP) * participationRate",
      "description": "개인 활동 포인트(AP)를 유닛 단위로 집계. 참여율과 팀워크에 따라 보너스/페널티 적용.",
      "refreshCycle": "실시간",
      "refreshInterval": null,
      "inputs": {
        "memberAP": {
          "description": "유닛 소속 개인들의 활동 포인트 합계",
          "source": "개인 AP (활동, 퀘스트, 거래, 창작 등에서 획득)"
        },
        "participationRate": {
          "description": "유닛 전체 인원 대비 활동 인원 비율",
          "formula": "activeMembersCount / totalMembersCount",
          "unit": "0.0 ~ 1.0"
        }
      },
      "multipliers": [
        {
          "id": "unit_aura",
          "name": "유닛 오라",
          "nameEn": "Unit Aura",
          "condition": "전원 출석 (참여율 100%)",
          "multiplier": 1.2,
          "description": "유닛 전원이 해당 주기에 활동했을 때 발동",
          "stackable": false
        },
        {
          "id": "sync_boost",
          "name": "동기화 부스트",
          "nameEn": "Sync Boost",
          "condition": "3명 이상 동시 활동",
          "multiplier": 2,
          "description": "같은 시간대에 3명 이상이 동시에 활동 중일 때 발동",
          "stackable": false,
          "detectionWindow": "30분 이내 동시 접속"
        },
        {
          "id": "combo_streak",
          "name": "콤보 스트릭",
          "nameEn": "Combo Streak",
          "condition": "7일 연속 유닛 활동",
          "multiplier": 1.5,
          "description": "유닛이 7일 연속으로 최소 1명 이상 활동했을 때 발동",
          "stackable": false,
          "resetCondition": "1일이라도 활동 없으면 초기화"
        }
      ],
      "penalties": [
        {
          "id": "low_participation",
          "name": "저참여 페널티",
          "nameEn": "Low Participation Penalty",
          "condition": "참여율 30% 미만",
          "multiplier": 0.5,
          "description": "유닛 활동 인원이 전체의 30% 미만일 때 에너지 반감"
        }
      ],
      "outputRange": {
        "min": "Σ(AP) × 0.5 × 0.3 (최악: 저참여 + 낮은 참여율)",
        "max": "Σ(AP) × 1.0 × 1.2 × 2.0 × 1.5 (최고: 유닛오라 + 동기화 + 콤보)",
        "theoreticalMaxMultiplier": 3.6,
        "note": "보너스 배율은 곱연산으로 중첩. 페널티는 보너스와 별도 적용."
      },
      "example": {
        "scenario": "유닛 10명, 전원 출석, 5명 동시활동, 7일 연속, 개인AP 합계 5000",
        "calculation": "5000 × 1.0(참여율) × 1.2(유닛오라) × 2.0(동기화) × 1.5(콤보) = 18,000",
        "result": 18000
      }
    },
    {
      "stage": 2,
      "name": "유닛 → 베이스",
      "nameEn": "Unit → Base",
      "id": "unit_to_base",
      "formula": "BaseEnergy = Σ(UnitEnergy) × SyncRate × 미션성공보너스",
      "formulaCode": "BaseEnergy = sum(unitEnergies) * syncRate * missionBonus",
      "description": "유닛 에너지를 베이스 단위로 합산. 베이스 동기화율과 미션 성공률에 따라 보정.",
      "refreshCycle": "1시간",
      "refreshInterval": 3600,
      "inputs": {
        "unitEnergies": {
          "description": "베이스 소속 모든 유닛의 에너지 합계",
          "source": "Stage 1 출력값"
        },
        "syncRate": {
          "description": "베이스 내 유닛 간 동기화율",
          "formula": "activatedUnits / totalUnits × interactionScore",
          "unit": "0.0 ~ 1.0",
          "note": "유닛 간 교류(합동 미션, 공동 이벤트) 빈도에 비례"
        }
      },
      "multipliers": [
        {
          "id": "mission_s_rank",
          "name": "S등급 미션 성공",
          "nameEn": "S-Rank Mission Success",
          "condition": "미션 성공률 90% 이상",
          "multiplier": 1.5,
          "description": "베이스 미션의 90% 이상을 성공했을 때"
        },
        {
          "id": "mission_a_rank",
          "name": "A등급 미션 성공",
          "nameEn": "A-Rank Mission Success",
          "condition": "미션 성공률 70% ~ 89%",
          "multiplier": 1.2,
          "description": "베이스 미션의 70~89%를 성공했을 때"
        }
      ],
      "penalties": [
        {
          "id": "mission_failure",
          "name": "미션 실패 페널티",
          "nameEn": "Mission Failure Penalty",
          "condition": "미션 성공률 50% 미만",
          "multiplier": 0.8,
          "description": "베이스 미션 성공률이 절반에 미치지 못할 때 에너지 20% 감소"
        }
      ],
      "missionSuccessTiers": [
        {
          "range": [
            90,
            100
          ],
          "grade": "S",
          "multiplier": 1.5,
          "label": "완벽한 작전 수행"
        },
        {
          "range": [
            70,
            89
          ],
          "grade": "A",
          "multiplier": 1.2,
          "label": "우수한 작전 수행"
        },
        {
          "range": [
            50,
            69
          ],
          "grade": "B",
          "multiplier": 1,
          "label": "기본 작전 수행"
        },
        {
          "range": [
            0,
            49
          ],
          "grade": "C",
          "multiplier": 0.8,
          "label": "작전 실패"
        }
      ],
      "example": {
        "scenario": "베이스 5개 유닛, 유닛에너지 합계 50000, 동기화율 0.85, 미션성공률 92%",
        "calculation": "50000 × 0.85 × 1.5 = 63,750",
        "result": 63750
      }
    },
    {
      "stage": 3,
      "name": "베이스 → 테리토리",
      "nameEn": "Base → Territory",
      "id": "base_to_territory",
      "formula": "TerritoryEnergy = Σ(BaseEnergy) × 경제가중치 × 방어보너스",
      "formulaCode": "TerritoryEnergy = sum(baseEnergies) * economicWeight * defenseBonus",
      "description": "베이스 에너지를 테리토리 단위로 합산. 경제력과 방어(정화) 활동에 따라 보정.",
      "refreshCycle": "매일 자정 (KST)",
      "refreshInterval": 86400,
      "inputs": {
        "baseEnergies": {
          "description": "테리토리 소속 모든 베이스의 에너지 합계",
          "source": "Stage 2 출력값"
