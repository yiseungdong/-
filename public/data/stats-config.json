  "calcTypes": {
    "time": {
      "label": "시간제",
      "description": "활동 시간(분)에 비례하여 AP 부여",
      "formula": "AP = clamp(활동시간, min, max)"
    },
    "count": {
      "label": "횟수제",
      "description": "활동 횟수에 비례하여 AP 부여 (일일 캡 적용 가능)",
      "formula": "AP = clamp(횟수 × 단가, min, max)"
    },
    "achievement": {
      "label": "성과제",
      "description": "활동 완료 시 성과 등급에 따라 AP 부여",
      "formula": "AP = 등급별 고정값 (min ~ max)"
    },
    "value": {
      "label": "가치비례제",
      "description": "투입된 가치(스타더스트)에 비례하여 AP 부여",
      "formula": "AP = clamp(가치 × 환산비, min, max)"
    }
