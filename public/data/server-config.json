    "description": "아스테리아 서버 인프라 설정",
    "runtime": "Node.js 20 LTS",
    "framework": "Express.js 4.x",
    "database": "PostgreSQL 15+",
    "cache": "Redis 7+",
    "realtime": "Socket.IO 4.x"
  },
  "projectStructure": {
    "description": "서버 디렉토리 구조 (server.js 진입점에서 모듈 분리)",
    "entryPoint": "server.js",
    "tree": {
