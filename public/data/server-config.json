        "redis.js": "Redis 클라이언트 설정",
        "cors.js": "CORS 허용 도메인/메서드 설정",
        "jwt.js": "JWT 서명/검증 설정 (RS256 키 쌍)",
        "rateLimit.js": "요청 제한 규칙 (인증/비인증/엔드포인트별)",
        "scheduler.js": "배치 작업 스케줄러 설정 (node-cron)"
      },
      "middleware/": {
        "cors.js": "CORS 미들웨어",
        "rateLimiter.js": "요청 속도 제한 미들웨어",
        "auth.js": "JWT 인증 미들웨어 (토큰 검증, 블랙리스트 체크)",
        "deviceCheck.js": "기기 검증 미들웨어 (제로티켓 HW 해시 5대 검증)",
        "popValidator.js": "PoP 엔진 활동 검증 미들웨어",
        "errorHandler.js": "전역 에러 핸들러 (12종 에러코드 매핑)"
      },
      "routes/": {
        "index.js": "라우터 통합 마운트",
        "auth.routes.js": "인증 라우트 (/api/v1/auth)",
        "user.routes.js": "유저 라우트 (/api/v1/users)",
        "stats.routes.js": "스탯 라우트 (/api/v1/stats)",
        "activity.routes.js": "활동 라우트 (/api/v1/activity)",
        "league.routes.js": "리그 라우트 (/api/v1/leagues)",
        "org.routes.js": "조직 라우트 (/api/v1/orgs)",
        "ark.routes.js": "방주 라우트 (/api/v1/arks)",
        "economy.routes.js": "경제 라우트 (/api/v1/economy)",
        "admin.routes.js": "관리자 라우트 (/api/v1/admin)",
        "agency.routes.js": "에이전시 라우트 (/api/v1/agency)"
      },
      "services/": {
        "auth.service.js": "인증/토큰 발급/갱신 로직",
        "user.service.js": "유저 CRUD, 프로필, 아키타입 갱신",
        "stats.service.js": "스탯 투자/조회/아키타입 산출",
        "activity.service.js": "활동 기록, AP 산출, PoP 처리",
        "league.service.js": "리그 랭킹, 시즌 관리, 승격/강등",
        "org.service.js": "조직 트리 CRUD, 에너지 합산",
        "ark.service.js": "방주/아티팩트 관리",
        "economy.service.js": "결제/구독/스타더스트/거래",
