  "middlewarePipeline": {
    "description": "미들웨어 실행 순서. 모든 요청은 이 파이프라인을 순서대로 통과한다.",
    "order": [
      {
        "step": 1,
        "name": "CORS",
        "file": "middleware/cors.js",
        "description": "Cross-Origin Resource Sharing 정책 적용",
        "config": {
          "allowedOrigins": [
            "https://asteria.app",
            "https://admin.asteria.app",
            "http://localhost:3000"
          ],
          "allowedMethods": [
            "GET",
            "POST",
            "PATCH",
            "DELETE",
            "OPTIONS"
          ],
          "allowedHeaders": [
            "Content-Type",
            "Authorization",
            "X-Device-Hash",
            "X-Request-ID"
          ],
          "credentials": true,
          "maxAge": 86400
        }
      },
      {
        "step": 2,
        "name": "Rate Limiter",
        "file": "middleware/rateLimiter.js",
        "description": "요청 속도 제한. DDoS 및 브루트포스 방지.",
        "config": {
          "store": "Redis (분산 환경 대응)",
          "rules": [
            {
              "target": "인증 유저",
              "limit": 100,
              "window": 60,
              "unit": "req/min"
            },
            {
              "target": "비인증",
              "limit": 20,
              "window": 60,
              "unit": "req/min"
            },
            {
              "target": "POST /auth/login",
              "limit": 5,
              "window": 300,
              "unit": "5회/5분 (브루트포스 방지)"
            },
            {
              "target": "POST /auth/register",
              "limit": 3,
              "window": 3600,
              "unit": "3회/시간"
            },
            {
              "target": "POST /economy/*",
              "limit": 10,
              "window": 60,
              "unit": "10회/분 (결제 남용 방지)"
            },
            {
              "target": "POST /regulation/reports",
              "limit": 5,
              "window": 3600,
              "unit": "5회/시간 (신고 남용 방지)"
            }
          ],
          "headers": {
            "remaining": "X-RateLimit-Remaining",
            "reset": "X-RateLimit-Reset"
          }
        }
      },
      {
        "step": 3,
        "name": "Auth (JWT)",
        "file": "middleware/auth.js",
        "description": "JWT 토큰 검증. 유효한 토큰이 없으면 인증 필요 엔드포인트 접근 차단.",
        "config": {
          "algorithm": "RS256",
          "tokenLocation": "Authorization: Bearer <token>",
          "blacklistCheck": "Redis 기반 토큰 블랙리스트 조회",
          "publicRoutes": [
            "POST /auth/login",
            "POST /auth/register",
            "POST /auth/refresh",
            "GET /leagues (공개 랭킹)",
            "GET /arks/:id (공개 방주 방문)"
          ],
          "userInjection": "검증 성공 시 req.user에 { id, level, starRank, integrityScore, status } 주입"
        }
      },
      {
        "step": 4,
        "name": "Device Check",
        "file": "middleware/deviceCheck.js",
        "description": "제로티켓 기기 검증. 최대 5대 기기까지 허용.",
        "config": {
          "maxDevices": 5,
          "headerName": "X-Device-Hash",
          "hashAlgorithm": "SHA-512",
          "checks": [
            "X-Device-Hash 헤더 존재 여부",
            "해시 형식 유효성 (128자 hex)",
            "DB의 zero_ticket_hw_hash와 대조",
            "동일 HW에서 등록된 계정 수 확인 (3개 이상 시 플래그)",
            "처벌 상태 확인 (영구추방된 HW인지)"
          ],
          "excludedRoutes": [
            "POST /auth/register (최초 등록 시에는 등록 로직으로 처리)"
          ],
          "failAction": "기기 미등록 또는 밴된 기기 → 403 Forbidden + ERR_DEVICE_BANNED"
        }
      },
      {
        "step": 5,
        "name": "PoP Validator",
        "file": "middleware/popValidator.js",
        "description": "활동 기록 엔드포인트에서 PoP(Proof of Participation) 검증 실행.",
        "config": {
          "appliedRoutes": [
            "POST /activity/*",
            "POST /stats/invest"
          ],
          "checks": [
            "클라이언트 타임스탬프 ↔ 서버 타임스탬프 차이 5초 이내",
            "클라이언트 해시 ↔ 서버 재계산 해시 일치",
            "활동 간 최소 간격 충족 (오라클 행동속도 규칙)",
            "중복 이벤트 방지 (idempotency key 검증)",
            "유령 필터 통과 여부"
          ],
          "failAction": "검증 실패 → AP 미지급 + 오라클 플래그 + ERR_POP_FAILED"
        }
      },
      {
        "step": 6,
        "name": "Route Handler",
        "file": "routes/*.routes.js",
        "description": "실제 비즈니스 로직 실행. Service 레이어 호출."
      },
      {
        "step": 7,
        "name": "Error Handler",
        "file": "middleware/errorHandler.js",
        "description": "전역 에러 캐처. 모든 미처리 에러를 통일된 형식으로 응답.",
        "config": {
          "format": "{ success: false, error: { code, message, detail }, timestamp }",
          "logging": "에러 발생 시 Winston으로 구조화 로그 기록",
          "sensitiveDataStrip": "스택트레이스, DB 쿼리 등 민감 정보는 production에서 제거"
        }
      }
    ]
  },
  "realtimeComputation": {
    "description": "실시간 연산 파이프라인. 활동 발생 시 즉시 처리되는 연쇄 계산.",
    "triggerEvent": "POST /activity/* 요청 처리 후",
    "pipeline": [
      {
        "step": 1,
        "name": "AP 산출",
        "service": "activity.service.js",
        "description": "기본 AP에 난이도 배율 적용하여 baseAP 결정",
        "formula": "baseAP = rawAP × difficultyModifier(sectorPhase)"
      },
      {
        "step": 2,
        "name": "보너스 적용",
        "service": "activity.service.js",
        "description": "4종 보너스 배율을 곱연산으로 적용",
        "multipliers": [
          {
            "name": "콤보 스트릭",
            "maxValue": 1.5,
            "condition": "7일 연속 활동",
            "source": "daily_activity.combo_day"
          },
          {
            "name": "동기화 부스트",
            "maxValue": 2,
            "condition": "3명+ 동시 활동",
            "source": "Redis 실시간 세션 카운트"
          },
          {
            "name": "난이도 보정",
            "range": "0.5x~2.5x",
            "condition": "섹터 성장 단계",
            "source": "fanclubs.member_count → phase 매핑"
          },
          {
            "name": "다영역 보너스",
            "value": 1.1,
            "condition": "5개+ 영역 활동",
            "source": "daily_activity.domain_count"
          }
        ],
        "formula": "finalAP = baseAP × combo × sync × difficulty × diversity",
        "cachePut": "Redis에 유저별 오늘의 AP 누적 캐싱 (TTL: 자정까지)"
      },
      {
        "step": 3,
        "name": "스탯 분배",
        "service": "stats.service.js",
        "description": "활동 영역(domain)에 따라 귀속 스탯에 경험치 반영",
        "mapping": {
          "quest": "ACT",
          "trade": "ECO",
          "create": "CRE",
          "social": "SOC",
          "pvp": "ACT+INT",
          "purify": "LOY",
          "event": "랜덤 (가중치 기반)"
        },
        "update": "user_stats 테이블 해당 스탯 값 증가"
      },
      {
        "step": 4,
        "name": "레벨/아키타입 갱신",
        "service": "user.service.js",
        "description": "XP 누적 확인 → 레벨업 여부 판정 → 아키타입 재계산",
        "subSteps": [
          "XP 누적량이 xp_to_next 이상이면 레벨업 처리",
          "레벨업 보상 지급 (스탯포인트 3 + 성궤슬롯 1 + AP 50 + 주권 +0.09)",
          "성계 등급 갱신 (10레벨 구간마다)",
          "6대 스탯 상위 2개 재계산 → 아키타입 변경 여부 판정 (하루 1회 제한)"
        ]
      },
      {
        "step": 5,
        "name": "조직 에너지 전파",
        "service": "energy.service.js",
        "description": "개인 AP 변동을 소속 유닛 에너지에 실시간 반영",
        "propagation": {
          "unit": "즉시 (Redis 캐시 갱신)",
          "base": "1시간 배치에서 합산",
          "territory": "자정 배치에서 합산",
          "fanclub": "자정 배치에서 합산"
        },
        "notification": "레벨업/아키타입 변경/유닛 보너스 발동 시 Socket.IO로 실시간 알림"
      }
    ]
  },
  "batchJobs": {
    "description": "배치 작업 스케줄러. node-cron 기반 정기 실행.",
    "scheduler": "node-cron",
    "lockMechanism": "Redis 분산 락 (다중 인스턴스 환경에서 중복 실행 방지)",
    "jobs": [
      {
        "id": "hourly_energy_snapshot",
        "name": "에너지 스냅샷",
        "cron": "0 * * * *",
        "schedule": "매시간 정각",
        "service": "scheduler.service.js → snapshotEnergy()",
        "description": "유닛→베이스 에너지 합산 및 energy_snapshots 테이블 기록",
        "steps": [
          "모든 유닛의 실시간 에너지 캐시(Redis) 수집",
          "베이스별 소속 유닛 에너지 합산 × syncRate × missionBonus",
          "energy_snapshots 테이블에 INSERT (유닛/베이스 레벨)",
          "Redis 캐시 갱신"
        ],
        "estimatedDuration": "30초 ~ 2분",
        "failurePolicy": "실패 시 5분 후 1회 재시도, 재실패 시 관리자 알림"
      },
      {
        "id": "daily_settlement",
        "name": "일일 정산",
        "cron": "0 0 * * *",
        "schedule": "매일 자정 (KST)",
        "service": "scheduler.service.js → dailySettlement()",
        "description": "테리토리/팬클럽 에너지 합산, 리그 순위 갱신, 일일 집계 마감",
        "steps": [
          "베이스→테리토리 에너지 합산 (경제가중치 × 방어보너스)",
          "테리토리→팬클럽 에너지 합산 (평판계수 × CP보너스)",
          "energy_snapshots 테이블에 INSERT (테리토리/팬클럽 레벨)",
          "리그별 팬클럽 순위 재계산 (fanclubs.rank 갱신)",
          "미러 랭킹 갱신 (상위 꼴찌 vs 하위 1등)",
          "daily_activity 마감 (combo_day 리셋 또는 증가)",
          "유령 필터 실행 (활동 시간 5분 미만 계정 마킹)",
          "캐치업 보너스 대상자 재계산"
        ],
        "estimatedDuration": "2분 ~ 10분",
        "failurePolicy": "실패 시 00:15에 재시도, 재실패 시 긴급 알림 + 수동 실행 대기"
      },
      {
        "id": "weekly_subgroup",
        "name": "소모임 평가",
        "cron": "0 0 * * 1",
        "schedule": "매주 월요일 자정 (KST)",
        "service": "scheduler.service.js → evaluateSubgroups()",
        "description": "유닛 단위 주간 성과 평가. 콤보/참여율/동기화 기반 보상 산정.",
        "steps": [
          "유닛별 주간 참여율/동기화율/미션성공률 집계",
          "우수 유닛 보상 지급 (AP 보너스, 유닛 오라 갱신)",
          "저참여 유닛 경고 발송 (참여율 30% 미만)",
          "유닛 간 미러 매칭 갱신"
        ],
        "estimatedDuration": "1분 ~ 5분",
        "failurePolicy": "실패 시 01:00에 재시도"
      },
      {
        "id": "monthly_season",
        "name": "시즌 정산 / 승격·강등",
        "cron": "0 0 L * *",
        "schedule": "매월 말일 자정 (KST)",
        "service": "scheduler.service.js → processSeasonEnd()",
        "description": "메인 리그 시즌 종료 처리. 승격/강등 판정, 시즌 보상 지급.",
        "steps": [
          "현재 시즌 종료 처리 (leagues.is_active = false)",
          "승격 공식 적용 (IAI/GSI/PII 가중치 × 리그별 승격률)",
          "승격 대상자 상위 리그 배치",
          "강등 대상자 하위 리그 배치 (최하위 10%, 퀘이사는 5%)",
          "노바→퀘이사 승격은 원로회 승인 대기열에 등록",
          "시즌 보상 일괄 지급 (AP, 스탯포인트, 성궤슬롯)",
          "주간 랭크 보상 정산 지급",
          "새 시즌 생성 (leagues INSERT, is_active = true)",
          "미러 랭킹 초기화",
          "시즌 리포트 생성 및 전체 공지"
        ],
        "estimatedDuration": "5분 ~ 30분",
        "failurePolicy": "실패 시 전체 롤백 + 긴급 관리자 알림. 수동 검증 후 재실행.",
        "critical": true
      }
    ]
  },
  "apiResponse": {
    "description": "API 응답 형식 통일 규격",
    "successFormat": {
      "structure": {
